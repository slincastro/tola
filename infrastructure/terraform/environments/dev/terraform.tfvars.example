aws_region = "us-east-1"  # Choose your preferred region
project_name = "tola"
environment = "dev"

# MongoDB Atlas configuration
mongodb_atlas_public_key = "your-public-key"  # Get this from MongoDB Atlas UI
mongodb_atlas_private_key = "your-private-key"  # Get this from MongoDB Atlas UI
mongodb_atlas_org_id = "your-organization-id"  # Get this from MongoDB Atlas UI
mongodb_db_username = "tola-app-user"
mongodb_db_password = "your-secure-password"  # Use a secure password

# The connection string is now generated by the MongoDB Atlas module
# mongodb_connection_string is kept for backward compatibility but not needed

# Other configurations
auth_enabled = false  # Set to true if you want to enable Cognito authentication
lambda_memory_size = 512
lambda_timeout = 15
